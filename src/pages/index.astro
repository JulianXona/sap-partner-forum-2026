---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ========================================
       CHAPTER 00 — HERO
       ======================================== -->
  <section class="section hero bg-noise" data-chapter="prólogo" data-chapter-num="00">
    <img src="/img/image4.webp" alt="" class="bg-cover hero-bg" data-scale-in />
    <div class="hero-overlay"></div>

    <!-- SAP Signature parallelogram stack — top right corner -->
    <svg class="hero-geo" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <!-- Parallelogram stack: outermost → innermost, dark → bright -->
      <polygon points="820,0 1440,0 1440,900 620,900" fill="#002A86" opacity="0.55"/>
      <polygon points="920,0 1440,0 1440,900 730,900" fill="#0050C8" opacity="0.45"/>
      <polygon points="1040,0 1440,0 1440,900 860,900" fill="#0070F2" opacity="0.35"/>
      <polygon points="1150,0 1440,0 1440,900 990,900" fill="#1B90FF" opacity="0.25"/>
      <polygon points="1270,0 1440,0 1440,900 1120,900" fill="#36A0FF" opacity="0.15"/>
      <!-- Thin white diagonal signature line -->
      <line x1="820" y1="0" x2="620" y2="900" stroke="white" stroke-width="0.8" opacity="0.25"/>
      <!-- Magenta accent line -->
      <line x1="920" y1="0" x2="730" y2="900" stroke="#E8508A" stroke-width="0.5" opacity="0.2"/>
    </svg>

    <div class="content container" style="position:relative; z-index:3;">
      <div class="hero-meta reveal">
        <span class="eyebrow">SAP Partner Forum · Latin America 2026</span>
      </div>

      <h1 class="hero-title">
        El Gran<br/><em>Blend</em><br/>de Latinoamérica
      </h1>

      <div class="hero-footer">
        <div class="reveal" data-delay="0.4">
          <p class="lede" style="max-width: 38ch;">
            Mendoza · 25 al 28 de Agosto, 2026.<br/>
            Donde el sol, la tierra y la tecnología propician nuestro mejor blend de ideas.
          </p>
        </div>
        <div class="hero-scroll reveal" data-delay="0.6">
          <span>Scroll para comenzar la cosecha</span>
          <div class="scroll-arrow"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========================================
       CHAPTER 01 — THE BLEND
       ======================================== -->
  <section class="section concept" data-chapter="el blend" data-chapter-num="01" data-pin>
    <div class="layer" data-stage>
      <div class="container-narrow" style="text-align:center;">
        <span class="eyebrow">01 · El Gran Blend</span>
        <h2 class="display-l" style="margin-top: 2rem;" data-split>
          En Latinoamérica, los negocios se construyen desde las relaciones humanas.
        </h2>
      </div>
    </div>

    <div class="layer" data-stage>
      <div class="container-narrow">
        <p class="lede" style="font-size: clamp(1.3rem, 2vw, 1.85rem); text-align:center; margin: 0 auto;">
          Nuestro ecosistema no es uniforme. Es <em class="italic-serif" style="color:var(--wine-gold);">rico, diverso y complejo.</em>
        </p>
      </div>
    </div>

    <div class="layer" data-stage>
      <div class="container-narrow" style="text-align:center;">
        <p class="lede" style="font-size: clamp(1.4rem, 2.2vw, 2rem); margin: 0 auto;">
          Somos como las distintas cepas que dan vida a un vino inolvidable.<br/><br/>
          <em class="italic-serif" style="color:var(--wine-gold);">Cada país aporta una uva</em><br/>
          con notas, texturas y aromas que solo su tierra de origen puede dar.
        </p>
      </div>
    </div>
  </section>

  <!-- ========================================
       CHAPTER 02 — THE WINEMAKER (Enólogo)
       ======================================== -->
  <section class="section enologo" data-chapter="el enólogo" data-chapter-num="02">
    <img src="/img/image6.webp" alt="" class="bg-cover" data-scale-in style="opacity: 0.45;" />
    <div class="scrim"></div>

    <div class="content container grid-2">
      <div>
        <span class="eyebrow reveal">02 · El Enólogo</span>
        <h2 class="display-l reveal" style="margin-top: 1.5rem;">
          El enólogo de la tecnología.
        </h2>
      </div>
      <div>
        <p class="lede reveal" style="margin-bottom: 1.5rem;">
          Separadas, nuestras cepas son extraordinarias. Pero el verdadero milagro de los
          negocios ocurre cuando se encuentran.
        </p>
        <p class="lede reveal" data-delay="0.2">
          Aquí es donde el <em class="italic-serif" style="color:var(--wine-gold);">SAP Partner Forum</em>
          toma su rol fundamental: el del enólogo. Nuestra misión no es cambiar la naturaleza
          de la uva, sino entenderla y brindarle el entorno, la tecnología y la paciencia para
          que alcance su máxima expresión.
        </p>
        <p class="lede reveal" data-delay="0.4" style="margin-top: 1.5rem; color:var(--wine-gold);">
          Así guiamos a nuestro ecosistema para lograr el Gran Ensamblaje.
        </p>
      </div>
    </div>
  </section>

  <!-- ========================================
       CHAPTER 03 — MENDOZA TERROIR
       ======================================== -->
  <section class="section terroir" data-chapter="mendoza" data-chapter-num="03">
    <img src="/img/image68.webp" alt="Cordillera y viñedos de Mendoza" class="bg-cover" data-scale-in />
    <div class="scrim"></div>

    <div class="content container" style="display: grid; grid-template-rows: 1fr auto; min-height: 80vh;">
      <div style="align-self: start;">
        <span class="eyebrow reveal">03 · Terruño de Evolución</span>
      </div>
      <div style="max-width: 50ch;">
        <h2 class="display-xl reveal" style="font-style: italic; font-weight: 200;">
          Mendoza.
        </h2>
        <p class="lede reveal" data-delay="0.2" style="margin-top: 2rem;">
          A los pies de los Andes y bajo su sol implacable, encontramos el suelo fértil para
          madurar nuestra confianza y la inspiración natural para potenciar la innovación.
        </p>
        <p class="lede reveal" data-delay="0.4" style="margin-top: 1rem; color:var(--wine-gold); font-style: italic;">
          Es en este terruño donde nuestro éxito colectivo se cultiva y cobra vida.
        </p>
      </div>
    </div>
  </section>

  <!-- ========================================
       CHAPTER 04 — STATEMENT
       ======================================== -->
  <section class="section statement bg-sparkles" data-chapter="el escenario" data-chapter-num="04">
    <!-- SAP parallelogram stack — left side espejado -->
    <svg class="statement-geo" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <!-- Left stack -->
      <polygon points="0,0 620,0 420,900 0,900" fill="#002A86" opacity="0.5"/>
      <polygon points="0,0 510,0 310,900 0,900" fill="#0050C8" opacity="0.4"/>
      <polygon points="0,0 390,0 200,900 0,900" fill="#0070F2" opacity="0.3"/>
      <polygon points="0,0 270,0 90,900 0,900" fill="#7858FF" opacity="0.2"/>
      <line x1="620" y1="0" x2="420" y2="900" stroke="white" stroke-width="0.8" opacity="0.2"/>
      <!-- Right stack — violet variant -->
      <polygon points="1440,0 1440,900 1020,900 1220,0" fill="#002A86" opacity="0.5"/>
      <polygon points="1440,0 1440,900 1130,900 1330,0" fill="#5D36FF" opacity="0.35"/>
      <polygon points="1440,0 1440,900 1240,900 1380,0" fill="#7858FF" opacity="0.2"/>
      <line x1="1220" y1="0" x2="1020" y2="900" stroke="white" stroke-width="0.8" opacity="0.2"/>
    </svg>
    <div class="content container-narrow" style="text-align:center;">
      <span class="eyebrow reveal">SAP Partner Forum Latin America · Mendoza 2026</span>
      <h2 class="display-xl reveal" style="margin-top: 2.5rem; line-height: 0.95;" data-delay="0.1">
        El escenario perfecto donde la <em class="italic-serif" style="background: linear-gradient(135deg, var(--wine-gold) 0%, var(--sap-magenta) 60%, #C040FF 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">tecnología impulsa el blend</em>
        de nuestro ecosistema.
      </h2>
    </div>
  </section>

  <!-- ========================================
       CHAPTER 05 — CONVOCATORIA
       ======================================== -->
  <section class="section convocatoria-intro" data-chapter="convocatoria" data-chapter-num="05">
    <div class="content container">
      <span class="eyebrow reveal">05 · Convocatoria</span>
      <h2 class="display-l reveal" style="margin-top: 1.5rem; max-width: 18ch;" data-delay="0.1">
        Convocar a las cepas más selectas para lograr el blend perfecto.
      </h2>
    </div>
  </section>

  <!-- TEASER VIDEO -->
  <section class="section teaser-section">
    <div class="content container grid-2" style="align-items: stretch;">
      <div>
        <span class="chip reveal">Teaser Video Invitación</span>
        <h3 class="display-m reveal" style="margin-top: 1.5rem;" data-delay="0.1">
          Donde el sol, la tierra y la tecnología propician nuestro mejor blend de ideas.
        </h3>
        <p class="lede reveal" data-delay="0.3" style="margin-top: 1.5rem;">
          Un video teaser sumerge a los partners en la majestuosidad de nuestro terruño
          mendocino y adelanta la exclusividad de la experiencia. Su objetivo es claro:
          <em class="italic-serif">SAP ha preparado el escenario perfecto</em> y la
          tecnología de vanguardia para potenciar la unión que nos hace distintos ante el
          resto del mundo.
        </p>
      </div>
      <div class="video-card reveal" data-delay="0.2">
        <div class="video-poster">
          <img src="/img/image3.webp" alt="" />
          <div class="play-btn"><svg viewBox="0 0 32 32"><path d="M10 6l16 10-16 10z" fill="currentColor"/></svg></div>
          <div class="video-meta">
            <span>0:90 · Teaser</span>
            <strong>SAP Partner Forum · Mendoza 2026</strong>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MICROSITIO + CONCIERGE -->
  <section class="section feature-pair">
    <div class="content container grid-2">
      <div class="feature-card reveal">
        <span class="chip">Micrositio</span>
        <h3 class="display-s" style="margin-top: 1rem;">Una plataforma para todo.</h3>
        <p class="lede" style="margin-top: 1rem;">
          Los invitados se registran, acceden a información, pagan sus entradas, cargan
          vuelos, coordinan traslados, solicitan requerimientos especiales y agendan sesiones
          1:1 con líderes de SAP y sponsors.
        </p>
        <ul class="feature-list">
          <li>Registro y pago seguro</li>
          <li>Gestión de vuelos y traslados</li>
          <li>Agenda de reuniones 1:1</li>
          <li>Concierge vía chatbot + WhatsApp</li>
        </ul>
      </div>
      <div class="feature-card reveal" data-delay="0.15">
        <span class="chip">Concierge Personalizado</span>
        <h3 class="display-s" style="margin-top: 1rem;">Acompañamiento sin fricciones.</h3>
        <p class="lede" style="margin-top: 1rem;">
          Nuestro diferencial clave comienza tras la conversión: desde el momento exacto de la
          compra, un servicio de Concierge exclusivo acompaña a cada invitado, garantizando
          una atención personalizada en cada etapa de su viaje.
        </p>
        <div class="kpi-row">
          <div><span class="big">24/7</span><span>Disponibilidad</span></div>
          <div><span class="big">1:1</span><span>Atención personal</span></div>
          <div><span class="big">∞</span><span>Solicitudes</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- FLOW DE COMUNICACIÓN -->
  <section class="section flow-section">
    <div class="content container">
      <span class="eyebrow reveal">Flow de Comunicación</span>
      <h2 class="display-m reveal" style="margin-top: 1rem;" data-delay="0.1">
        Una conversación que crece como una cosecha.
      </h2>
      <p class="lede reveal" data-delay="0.2" style="margin-top: 1rem; max-width: 60ch;">
        Diez puntos de contacto cuidadosamente orquestados entre mayo y agosto, cada uno con
        un propósito y un tono propios.
      </p>

      <div class="timeline-grid">
        <div class="tl-month reveal"><span>MAY</span></div>
        <div class="tl-step reveal"><span class="tl-date">26 May</span><strong>Save The Date</strong><p>Anuncio oficial</p></div>

        <div class="tl-month reveal" data-delay="0.1"><span>JUN</span></div>
        <div class="tl-step reveal" data-delay="0.1"><span class="tl-date">3 Jun</span><strong>Invitación</strong><p>Plataforma online con highlights</p></div>
        <div class="tl-step reveal" data-delay="0.15"><span class="tl-date">26 Jun</span><strong>Push Toque 1</strong><p>Recordatorio personalizado</p></div>

        <div class="tl-month reveal" data-delay="0.2"><span>JUL</span></div>
        <div class="tl-step reveal" data-delay="0.2"><span class="tl-date">14 Jul</span><strong>Push Toque 2</strong><p>Highlights · info · agenda</p></div>

        <div class="tl-month reveal" data-delay="0.3"><span>AGO</span></div>
        <div class="tl-step reveal" data-delay="0.3"><span class="tl-date">3 Ago</span><strong>Push Toque 3</strong><p>Todavía no te registraste · link to register</p></div>
        <div class="tl-step reveal" data-delay="0.35"><span class="tl-date">10 Ago</span><strong>Last Chance</strong><p>Cierre de registros</p></div>
        <div class="tl-step reveal" data-delay="0.4"><span class="tl-date">18 Ago</span><strong>Info Agenda</strong><p>Final agenda · speakers</p></div>
        <div class="tl-step reveal" data-delay="0.45"><span class="tl-date">24 Ago</span><strong>Pack your bags</strong><p>Logística final</p></div>
        <div class="tl-step reveal" data-delay="0.5"><span class="tl-date">28 Ago</span><strong>See you tomorrow</strong><p>Bienvenida inminente</p></div>
        <div class="tl-step reveal closing" data-delay="0.55"><span class="tl-date">29 Ago</span><strong>Thank You</strong><p>Cosecha compartida</p></div>
      </div>
    </div>
  </section>

  <!-- ========================================
       CHAPTER 06 — UBICACIÓN
       ======================================== -->
  <section class="section location-intro" data-chapter="ubicación" data-chapter-num="06">
    <div class="content container">
      <span class="eyebrow reveal">06 · Ubicación</span>
      <h2 class="display-l reveal" style="margin-top: 1.5rem;" data-delay="0.1">
        Hospedaje y Centros de Convenciones.
      </h2>
      <p class="lede reveal" data-delay="0.2" style="margin-top: 1rem; max-width: 60ch;">
        Dos opciones cuidadosamente diseñadas: la inmersión total en el Valle de Luján de
        Cuyo, o la energía de Mendoza Ciudad con sus 5 estrellas históricos.
      </p>
    </div>
    <div class="map-wrap reveal" data-delay="0.3">
      <img src="/img/image20.webp" alt="Mapa de ubicaciones en Mendoza" />
    </div>
  </section>

  <!-- ========================================
       CHAPTER 07 — ARRIVALS HOSPITALITY
       ======================================== -->
  <section class="section arrivals-intro" data-chapter="bienvenida" data-chapter-num="07">
    <img src="/img/image24.webp" alt="" class="bg-cover" data-scale-in style="opacity:0.4;" />
    <div class="scrim"></div>

    <div class="content container">
      <span class="eyebrow reveal">07 · Arrivals Hospitality</span>
      <h2 class="display-l reveal" style="margin-top: 1.5rem; max-width: 22ch;" data-delay="0.1">
        El primer contacto con el terruño.
      </h2>
      <p class="lede reveal" data-delay="0.3" style="margin-top: 1.5rem; max-width: 55ch;">
        Recibiendo a las cepas que darán vida a nuestro Gran Blend. Desde el aeropuerto,
        cada gesto está pensado para anclar al partner en el espíritu de Partner Valley.
      </p>
    </div>
  </section>

  <!-- ARRIVAL STEPS — horizontal scroll -->
  <section class="section h-scroll-section" data-hscroll>
    <div class="h-scroll-track" data-hscroll-track>

      <div class="h-scroll-panel" data-hscroll-panel>
        <div class="arrival-card">
          <div class="arrival-media"><img src="/img/image24.webp" alt="" /></div>
          <div class="arrival-body">
            <span class="chip">Paso 1 · Aeropuerto</span>
            <h3 class="display-s">Bienvenida performática</h3>
            <p class="lede">
              Un actor caracterizado como productor vitivinícola recibe a cada partner
              para darle la bienvenida oficial a Partner Valley y entregar el
              <em class="italic-serif">Welcome Refreshment Kit</em>:
            </p>
            <ul class="kit-list">
              <li>Agua mineral</li>
              <li>Snack saludable</li>
              <li>Toallita refrescante</li>
              <li>Mapa / booklet turístico</li>
              <li>Tarjetón de bienvenida premium</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="h-scroll-panel" data-hscroll-panel>
        <div class="arrival-card">
          <div class="arrival-media"><img src="/img/image17.webp" alt="" /></div>
          <div class="arrival-body">
            <span class="chip">Paso 2 · Traslados</span>
            <h3 class="display-s">Vehículos privados.</h3>
            <p class="lede">
              Cada invitado es acompañado por nuestro equipo de hospitalidad y trasladado
              a su hotel en vehículos privados. Movilidad a medida, máxima puntualidad y
              confort para que el trayecto esté a la altura de la experiencia.
            </p>
          </div>
        </div>
      </div>

      <div class="h-scroll-panel" data-hscroll-panel>
        <div class="arrival-card">
          <div class="arrival-media"><img src="/img/image31.webp" alt="" /></div>
          <div class="arrival-body">
            <span class="chip">Paso 3 · Registro</span>
            <h3 class="display-s">Lanyard etiqueta de vino.</h3>
            <p class="lede">
              Durante el registro, cada invitado recibe un lanyard inspirado en una etiqueta
              de vino, integrado a la narrativa visual de Partner Valley. Incluye un QR que
              da acceso a un booklet turístico de Mendoza.
            </p>
          </div>
        </div>
      </div>

      <div class="h-scroll-panel" data-hscroll-panel>
        <div class="arrival-card">
          <div class="arrival-media"><img src="/img/image29.webp" alt="" /></div>
          <div class="arrival-body">
            <span class="chip">Paso 4 · IA Partner's Blend</span>
            <h3 class="display-s">Tu perfil, en lenguaje de vino.</h3>
            <p class="lede">
              Una estación con IA pregunta sobre estilo de liderazgo, industria y visión.
              Devuelve un perfil único:
            </p>
            <ul class="kit-list">
              <li>Cepa dominante</li>
              <li>Nota de innovación</li>
              <li>Nivel de maduración</li>
              <li>Maridaje ideal en el ecosistema</li>
              <li>Oportunidad recomendada</li>
            </ul>
            <p class="caption" style="margin-top:1rem; color: var(--wine-gold); font-style: italic;">
              Ej: "Malbec Visionario"
            </p>
          </div>
        </div>
      </div>

      <div class="h-scroll-panel" data-hscroll-panel>
        <div class="arrival-card">
          <div class="arrival-media"><img src="/img/image16.webp" alt="" /></div>
          <div class="arrival-body">
            <span class="chip">Paso 5 · Check-in & Help Desk</span>
            <h3 class="display-s">Asistencia permanente.</h3>
            <p class="lede">
              Concierge presente desde la llegada al hotel: check-in, acreditación,
              reuniones 1:1, traslados, atención multilingüe. Punto físico + WhatsApp + QR.
            </p>
          </div>
        </div>
      </div>

      <div class="h-scroll-panel" data-hscroll-panel>
        <div class="arrival-card">
          <div class="arrival-media"><img src="/img/image27.webp" alt="" /></div>
          <div class="arrival-body">
            <span class="chip">Paso 6 · Welcome Kit</span>
            <h3 class="display-s">Tres piezas que cuentan una historia.</h3>
            <ul class="kit-detail">
              <li>
                <strong>Tarjetón Bienvenida</strong>
                <p>Alto gramaje, primera pieza premium de Partner Valley.</p>
              </li>
              <li>
                <strong>Símbolo del Terruño</strong>
                <p>Frasco de cristal lacrado con tierra auténtica de Luján de Cuyo. Primera pieza del juego coleccionable.</p>
              </li>
              <li>
                <strong>Delantal del Terruño</strong>
                <p>Gabardina gruesa con correas de cuero, bordado con SAP Partner Forum 2026.</p>
              </li>
            </ul>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ========================================
       CHAPTER 08 — THE PARTNER VALLEY (Hospedaje)
       ======================================== -->
  <section class="section valley-intro" data-chapter="partner valley" data-chapter-num="08">
    <div class="content container-narrow" style="text-align:center;">
      <span class="eyebrow reveal">08 · The Partner Valley</span>
      <h2 class="display-l reveal" style="margin-top: 1.5rem;" data-delay="0.1" data-split>
        Dos formas de habitar el valle.
      </h2>
    </div>
  </section>

  <section class="section options-section">
    <div class="content container grid-2" style="gap: 3rem;">
      <article class="option-card option-a reveal">
        <div class="option-img"><img src="/img/image14.webp" alt="Luján de Cuyo" /></div>
        <div class="option-body">
          <span class="chip">Opción A</span>
          <h3 class="display-s" style="margin-top: 0.75rem;">Luján de Cuyo</h3>
          <p class="lede" style="margin-top: 1rem;">
            Ecosistema 100% inmersivo: una red exclusiva de <strong>20 hoteles boutique y de
            montaña</strong>, ubicados estratégicamente alrededor de Finca Altos de Malbec,
            nuestro Centro de Convenciones principal.
          </p>
          <p style="margin-top:1rem;">
            Privacidad, confort de alto nivel y descanso reparador frente a la
            <em class="italic-serif">Cordillera de los Andes</em>.
          </p>
        </div>
      </article>

      <article class="option-card option-b reveal" data-delay="0.15">
        <div class="option-img"><img src="/img/image15.webp" alt="Mendoza Ciudad" /></div>
        <div class="option-body">
          <span class="chip">Opción B</span>
          <h3 class="display-s" style="margin-top: 0.75rem;">Mendoza Ciudad</h3>
          <p class="lede" style="margin-top: 1rem;">
            Concentración en el centro histórico, en los dos hoteles cinco estrellas más
            prestigiosos: <strong>Diplomatic Hotel</strong> y <strong>Park Hyatt Mendoza</strong>.
          </p>
          <p style="margin-top:1rem;">
            Centro de Convenciones: <em class="italic-serif">Espacio Arizu</em> o
            <em class="italic-serif">Finca Decero</em>, a 20 minutos de los hoteles.
          </p>
        </div>
      </article>
    </div>
  </section>

  <!-- ========================================
       CHAPTER 09 — CENTRO DE CONVENCIONES
       ======================================== -->
  <section class="section venue-intro" data-chapter="el venue" data-chapter-num="09">
    <div class="content container">
      <span class="eyebrow reveal">09 · El Corazón del Terruño</span>
      <h2 class="display-l reveal" style="margin-top: 1.5rem;" data-delay="0.1">
        Centro de Convenciones.
      </h2>

      <div class="venue-grid">
