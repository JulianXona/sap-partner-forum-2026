---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'SAP Partner Forum Latin America 2026 — Mendoza',
  description = 'El Gran Blend de Latinoamérica. Donde el sol, la tierra y la tecnología propician nuestro mejor blend de ideas. Mendoza, 25–28 de agosto de 2026.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0A0A0F" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,200..700;1,9..144,200..700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="progress-rail"><div class="progress-bar" id="progress-bar"></div></div>
    <div class="brand-mark">
      <span class="dot"></span>
      <span>SAP Partner Forum · Mendoza 2026</span>
    </div>
    <div class="chapter-counter">
      <span class="num" id="chapter-num">00</span>
      <span id="chapter-name">prólogo</span>
    </div>

    <main><slot /></main>

    <script>
      import '../scripts/scroll.ts';
    </script>
  </body>
</html>
